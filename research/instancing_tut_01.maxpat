, 							{
								"box" : 								{
									"code" : "// Change these params from Max (e.g., \"num_symbols 25.\") to match \n// the number of images currently loaded in your atlases!\nParam num_symbols(52.0);\nParam num_patterns(4.0);\n\n// 1. Random Scale (between 0.1 and 0.4 so they fit on screen)\nscale_x = (abs(noise()) * 0.9) + 0.5;\nscale_y = (abs(noise()) * 0.9) + 0.5;\n\n// 2. Random Atlas Indices\n// Multiplying by our total count and using floor() gives us perfect integers \n// (e.g., 0, 1, 2, 3...) to target specific Z-slices in the atlas.\nsym_idx = floor(abs(noise()) * num_symbols);\npat_idx = floor(abs(noise()) * num_patterns);\n\n// Pack to vec4: ScaleX, ScaleY, SymbolIndex, PatternIndex\nout1 = vec(scale_x, scale_y, sym_idx, pat_idx);",
									"fontface" : 0,
									"fontname" : "<Monospaced>",
									"fontsize" : 12.0,
